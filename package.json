{
  "name": "flowboard-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:push": "npm run prisma:push -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
